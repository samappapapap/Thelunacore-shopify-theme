            "icon_heading_size": "h3",
            "icon_text_alignment": "left",
            "title": "Weighted Calm",
            "text": "<p>200g of gentle pressure activates your body's natural relaxation response — the same science behind weighted blankets, applied directly where it works best.</p>",
            "margin_top": 20,
            "margin_bottom": 30
          }
        },
        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-icon_with_text-2": {
