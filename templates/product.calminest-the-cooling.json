        "template--21507361800487__8beb6911-28c6-482c-976a-e5421ad3e8df-richtext-1": {
          "type": "richtext",
          "settings": {
            "column": "col_1",
            "visibility": "always-display",
            "text": "<p>Most sleep products treat the symptoms. LunaCore treats the cause. By combining scientifically-backed weighted pressure with total-blackout design, we give your mind and body the exact signals they need to shut down — and stay down.</p>",
            "text_style": "body",
            "alignment": "center",
