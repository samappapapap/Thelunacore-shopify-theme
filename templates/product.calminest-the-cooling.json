            "icon_heading_size": "h3",
            "icon_text_alignment": "left",
            "title": "Pitch-Black Blackout",
            "text": "<p>Even the tiniest sliver of light disrupts melatonin. LunaCore blocks 100% — street lights, phone screens, early sunrise, all of it.</p>",
            "margin_top": 20,
