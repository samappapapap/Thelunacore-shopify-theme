olor: #6B7280;\n    margin-bottom: 30px;\n    font-weight: 500;\n  }\n\n  .luna-trust-badges {\n    display: flex;\n    justify-content: center;\n    gap: 50px;\n    flex-wrap: wrap;\n    align-items: center;\n  }\n\n  .luna-trust-badge {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .luna-trust-icon {\n    width: 50px;\n    height: 50px;\n    stroke: var(--luna-pink);\n    stroke-width: 1.5;\n  }\n\n  .luna-trust-label {\n    font-size: 13px;\n    font-weight: 600;\n    color: var(--luna-black);\n  }\n\n  \/* --- CTA BOX --- *\/\n  .luna-cta-box {\n    text-align: center;\n    background: var(--luna-bg-light);\n    padding: 60px 30px;\n    border-radius: 12px;\n    border: 1px solid #E5E7EB;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .luna-cta-box::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 4px;\n    background: linear-gradient(90deg, var(--luna-pink) 0%, #E8B4C8 100%);\n  }\n\n  .luna-cta-box h3 {\n    font-size: 32px;\n    margin-bottom: 16px;\n    line-height: 1.2;\n  }\n\n  .luna-cta-box p {\n    font-size: 17px;\n    margin-bottom: 30px;\n    color: var(--luna-grey);\n    max-width: 600px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n\n  .luna-btn {\n    background-color: var(--luna-pink);\n    color: #FFFFFF;\n    padding: 18px 50px;\n    text-decoration: none;\n    font-family: 'Inter', sans-serif;\n    font-weight: 600;\n    font-size: 16px;\n    letter-spacing: 0.3px;\n    border-radius: 8px;\n    transition: all 0.25s ease;\n    display: inline-block;\n    box-shadow: 0 4px 12px rgba(243, 197, 212, 0.3);\n    border: none;\n    cursor: pointer;\n  }\n\n  .luna-btn:hover {\n    background-color: #E8B4C8;\n    transform: translateY(-2px);\n    box-shadow: 0 6px 20px rgba(243, 197, 212, 0.4);\n  }\n\n  .luna-guarantee-text {\n    display: block;\n    margin-top: 20px;\n    font-size: 14px;\n    color: #6B7280;\n  }\n\n  .luna-guarantee-text strong {\n    font-weight: 600;\n    color: #4B5563;\n  }\n\n  \/* Scarcity text *\/\n  .luna-scarcity-text {\n    display: block;\n    margin-top: 12px;\n    font-size: 13px;\n    color: #EF4444;\n    font-weight: 600;\n  }\n\n  \/* --- MOBILE --- *\/\n  @media (max-width: 768px) {\n    .luna-container {\n      padding: 60px 20px;\n    }\n    .luna-title-main { \n      font-size: 32px; \n    }\n    .luna-subtitle-main {\n      font-size: 16px;\n    }\n    .luna-stats-bar {\n      gap: 30px;\n    }\n    .luna-stat-number {\n      font-size: 24px;\n    }\n    .luna-split-section { \n      flex-direction: column-reverse; \n      gap: 40px; \n      margin-bottom: 60px;\n    }\n    .luna-text-col h2 {\n      font-size: 26px;\n    }\n    .luna-img-badge {\n      top: 10px;\n      right: 10px;\n      padding: 8px 12px;\n      font-size: 11px;\n    }\n    .luna-features-grid {\n      grid-template-columns: 1fr;\n      gap: 30px;\n    }\n    .luna-section-title {\n      font-size: 28px;\n    }\n    .luna-trust-badges {\n      gap: 30px;\n    }\n    .luna-cta-box {\n      padding: 40px 24px;\n    }\n    .luna-cta-box h3 {\n      font-size: 26px;\n    }\n    .luna-btn {\n      padding: 16px 40px;\n      font-size: 15px;\n    }\n    .luna-comparison-table {\n      font-size: 13px;\n    }\n  }\n<\/style>\n\n<div class=\"luna-wrapper\">\n  <div class=\"luna-container\">\n\n    <!-- Header Section -->\n    <div class=\"luna-header-section\">\n      <div class=\"luna-urgency-banner\">\n        ⚡ 147 women bought Luna Nord in the last 48 hours\n      <\/div>\n      \n      <span class=\"luna-eyebrow\">The Luna Nord Story<\/span>\n      <h1 class=\"luna-title-main\">\n        You've Tried <span class=\"highlight\">Everything<\/span>. Nothing Worked.\n      <\/h1>\n      <p class=\"luna-subtitle-main\">\n        <strong>5 sleep masks, 3 weighted blankets, $500+ spent.<\/strong> You still lie awake for 1-2 hours replaying tomorrow's to-do list. We built Luna N