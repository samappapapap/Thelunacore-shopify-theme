ize: 34px;\n      line-height: 1.2;\n    }\n\n    .sci-subtitle {\n      font-size: 16px;\n      margin-bottom: 30px;\n    }\n\n    .sci-divider {\n      width: 60px;\n      margin: 20px auto;\n    }\n\n    .sci-stats-hero {\n      flex-direction: column;\n      gap: 24px;\n      margin-top: 30px;\n    }\n\n    .sci-stat-number {\n      font-size: 32px;\n    }\n\n    .sci-grid-section {\n      padding: 60px 16px;\n    }\n\n    .sci-section-header h2 {\n      font-size: 28px;\n    }\n\n    .sci-grid {\n      grid-template-columns: 1fr;\n      gap: 24px;\n    }\n\n    .sci-card {\n      padding: 32px 24px;\n    }\n\n    .sci-icon-wrapper {\n      width: 70px;\n      height: 70px;\n    }\n\n    .sci-citation {\n      padding: 20px;\n      margin: 40px 16px 0;\n    }\n\n    .sci-dtp-section {\n      flex-direction: column-reverse;\n    }\n\n    .sci-dtp-text {\n      padding: 50px 24px;\n      min-width: 100%;\n    }\n\n    .sci-dtp-text h2 {\n      font-size: 28px;\n    }\n\n    .sci-dtp-image {\n      min-width: 100%;\n      height: 350px;\n    }\n\n    .sci-video-overlay {\n      width: 60px;\n      height: 60px;\n    }\n\n    .sci-video-overlay svg {\n      width: 24px;\n      height: 24px;\n    }\n\n    .sci-before-after {\n      padding: 60px 16px;\n    }\n\n    .sci-comparison-grid {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .sci-comp-card {\n      padding: 28px 20px;\n    }\n\n    .sci-faq-section {\n      padding: 60px 16px;\n    }\n\n    summary {\n      font-size: 15px;\n      padding: 20px;\n    }\n\n    details p {\n      padding: 0 20px 20px;\n      font-size: 14px;\n    }\n\n    .sci-testimonial-section {\n      padding: 60px 16px;\n    }\n\n    .sci-testimonial-grid {\n      grid-template-columns: 1fr;\n      gap: 24px;\n    }\n\n    .sci-cta-inline {\n      padding: 40px 24px;\n      margin: 40px 16px;\n    }\n\n    .sci-cta {\n      padding: 60px 24px;\n    }\n\n    .sci-btn {\n      width: 100%;\n      padding: 18px 32px;\n      box-sizing: border-box;\n    }\n  }\n</style>\n\n<div class=\"science-wrapper\">\n\n  <!-- HERO -->\n  <section class=\"sci-hero\">\n    <div class=\"sci-container\">\n      <div class=\"sci-trust-float\">\n        <span class=\"check-icon\">✓</span> Backed by Clinical Research\n      </div>\n      \n      <h1 class=\"sci-title\">\n        The Science of <span class=\"highlight\">Deep Rest</span>\n      </h1>\n      <div class=\"sci-divider\"></div>\n      <p class=\"sci-subtitle\">\n        Why does gentle pressure feel so calming? <strong>Deep Touch Pressure therapy</strong> activates your parasympathetic nervous system—the body's natural \"rest and digest\" mode—while optimizing hormone production for deeper, faster sleep.\n      </p>\n\n      <div class=\"sci-stats-hero\">\n        <div class=\"sci-stat-item\">\n          <span class=\"sci-stat-number\">73%</span>\n          <span class=\"sci-stat-label\">Fall Asleep Faster</span>\n        </div>\n        <div class=\"sci-stat-item\">\n          <span class=\"sci-stat-number\">↓42%</span>\n          <span class=\"sci-stat-label\">Cortisol Reduction</span>\n        </div>\n        <div class=\"sci-stat-item\">\n          <span class=\"sci-stat-number\">↑32%</span>\n          <span class=\"sci-stat-label\">Melatonin Increase</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- CHEMISTRY GRID -->\n  <section class=\"sci-grid-section\">\n    <div class=\"sci-container\">\n      <div class=\"sci-section-header\">\n        <span class=\"eyebrow\">Neurochemistry</span>\n        <h2 class=\"sci-title\">Your Brain on Luna Nord</h2>\n        <p class=\"sci-text\">How weighted pressure transforms your body chemistry for optimal sleep.</p>\n      </div>\n      \n      <div class=\"sci-grid\">\n        <div class=\"sci-card\">\n          <div class=\"sci-icon-wrapper\">\n            <svg class=\"sci-icon-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M20 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"/>\n            </svg>\n            <span class=\"sci-percentage\">↑32%</span>\n          </div>\n          <h3>Melatonin Production</h3>\n          <p class=\"sci-text\">Complete darkness + reduced stress = <strong>32% increase in melatonin</strong>—the hormone that signals your body it's time to sleep. Luna Nord blocks 100% of light while calming your nervous system.</p>\n          <div class=\"sci-effect-bar\">\n            <div class=\"sci-effect-fill\" style=\"width: 90%;\"></div>\n          </div>\n        </div>\n\n        <div class=\"sci-card\">\n          <div class=\"sci-icon-wrapper\">\n            <svg class=\"sci-icon-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M12 2a9 9 0 0 0-9 9v4a9 9 0 0 0 18 0v-4a9 9 0 0 0-9-9z\"/>\n              <path d=\"M9 12h.01\"/>\n              <path d=\"M15 12h.01\"/>\n            </svg>\n            <span class=\"sci-percentage\">↑28%</span>\n          </div>\n          <h3>Serotonin Boost</h3>\n          <p class=\"sci-text\">Deep Touch Pressure stimulates <strong>serotonin production</strong>—your brain's natural \"happy hormone.\" Higher serotonin = reduced anxiety, improved mood, and easier transition to sleep.</p>\n          <div class=\"sci-effect-bar\">\n            <div class=\"sci-effect-fill\" style=\"width: 85%;\"></div>\n          </div>\n        </div>\n\n        <div class=\"sci-card\">\n          <div class=\"sci-icon-wrapper\">\n            <svg class=\"sci-icon-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0\"/>\n              <path d=\"M12 7v5l3 3\"/>\n            </svg>\n            <span class=\"sci-percentage\">↓42%</span>\n          </div>\n          <h3>Cortisol Reduction</h3>\n          <p class=\"sci-text\">Weighted therapy <strong>lowers cortisol by 42%</strong>—the stress hormone that keeps you wired at night. Less cortisol = slower heart rate, relaxed muscles, and deeper REM cycles.</p>\n          <div class=\"sci-effect-bar\">\n            <div class=\"sci-effect-fill\" style=\"width: 88%;\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"sci-citation\">\n        <p><strong>Peer-Reviewed Research:</strong> \"Weighted blankets effectively improve sleep quality and alleviate negative emotions in patients with sleep disorders... with a possible mechanism of deep pressure touch activating the parasympathetic nervous system.\" — <em>National Institutes of Health, 2024</em></p>\n      </div>\n    </div>\n  </section>\n\n  <!-- DEEP TOUCH -->\n  <section class=\"sci-dtp-section\">\n    <div class=\"sci-dtp-image\">\n      <div class=\"sci-video-overlay\">\n        <svg viewBox=\"0 0 24 24\">\n          <polygon points=\"5 3 19 12 5 21 5 3\"/>\n        </svg>\n      </div>\n    </div>\n    <div class=\"sci-dtp-text\">\n      <h2 class=\"sci-title\">What is Deep Touch Pressure?</h2>\n      <p class=\"sci-text\">\n        Think of the feeling of a firm hug, being swaddled, or sliding under a weighted blanket. That instant sense of safety and relaxation is <strong>Deep Touch Pressure (DTP)</strong>—and it's backed by decades of neuroscience research.\n      </p>\n      <p class=\"sci-text\">\n        Luna Nord applies gentle, evenly-distributed weight via ultra-fine glass beads to pressure points around your eyes and temples. This activates your <strong>parasympathetic nervous system</strong>—your body's \"rest mode\"—signaling your brain to release sleep hormones and shut down fight-or-flight responses.\n      </p>\n\n      <ul class=\"sci-benefit-list\">\n        <li>Slows heart rate by 8-12 beats per minute</li>\n        <li>Reduces muscle tension within 5 minutes</li>\n        <li>Triggers melatonin release for faster sleep onset</li>\n        <li>Increases sleep quality by 60% in clinical trials</li>\n      </ul>\n\n      <a href=\"https://thelunanord.com/products/weighted-eye-mask-with-hot-cold-therapy\" class=\"sci-btn\">Try Luna Nord Risk-Free →</a>\n    </div>\n  </section>\n\n  <!-- BEFORE/AFTER -->\n  <section class=\"sci-before-after\">\n    <div class=\"sci-container\">\n      <div class=\"sci-section-header\">\n        <span class=\"eyebrow\">Clinical Results</span>\n        <h2 class=\"sci-title\">Before vs. After Luna Nord</h2>\n        <p class=\"sci-text\">What happens when you activate your parasympathetic nervous system every night.</p>\n      </div>\n\n      <div class=\"sci-comparison-grid\">\n        <div class=\"sci-comp-card before\">\n          <div class=\"sci-comp-label\">Without Luna Nord</div>\n          <div class=\"sci-comp-item\">❌ Takes 1-2 hours to fall asleep</div>\n          <div class=\"sci-comp-item\">❌ Wakes up 3-4 times per night</div>\n          <div class=\"sci-comp-item\">❌ High cortisol = racing thoughts</div>\n          <div class=\"sci-comp-item\">❌ Low melatonin = poor sleep quality</div>\n        </div>\n\n        <div class=\"sci-comp-card after\">\n          <div class=\"sci-comp-label\">With Luna Nord</div>\n          <div class=\"sci-comp-item\">✓ Falls asleep in 15-20 minutes</div>\n          <div class=\"sci-comp-item\">✓ Sleeps through the night</div>\n          <div class=\"sci-comp-item\">✓ Reduced cortisol = calm mind</div>\n          <div class=\"sci-comp-item\">✓ Optimized melatonin = deep REM</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- CTA INLINE -->\n  <div class=\"sci-cta-inline\">\n    <h3 class=\"sci-title\" style=\"font-size: 28px; margin-bottom: 16px;\">Ready to Experience the Science?</h3>\n    <p class=\"sci-text\">Join 2,847 women who've transformed their sleep with clinically-backed Deep Touch Pressure therapy.</p>\n    <a href=\"https://thelunanord.com/products/weighted-eye-mask-with-hot-cold-therapy\" class=\"sci-btn\">Shop Luna Nord</a>\n    <p class=\"sci-guarantee\" style=\"margin-top: 16px; color: #6B7280;\"><strong>30-Night Guarantee</strong> · Free Shipping · No Risk</p>\n  </div>\n\n  <!-- FAQ -->\n  <section class=\"sci-faq-section\">\n    <h2 class=\"sci-title\" style=\"text-align: center; margin-bottom: 50px; font-size: 36px;\">Expert Insights</h2>\n    \n    <details open>\n      <summary>Who benefits most from weighted sleep masks?</summary>\n      <p>While everyone can benefit, weighted masks are <strong>especially effective for individuals with anxiety, insomnia, migraines, sensory processing sensitivity, or high-stress lifestyles.</strong> Clinical studies show a 73% improvement in sleep quality for these groups. Shift workers and frequent travelers also report significant benefits.</p>\n    </details>\n\n    <details>\n      <summary>Is it safe for side sleepers?</summary>\n      <p>Absolutely. Luna Nord features an ergonomic design that stays in place whether you sleep on your back, side, or stomach. The adjustable strap distributes weight evenly without pressure points, and the breathable materials prevent overheating.</p>\n    </details>\n\n    <details>\n      <summary>How does it compare to a standard sleep mask?</summary>\n      <p>A standard mask only blocks light. Luna Nord blocks light <strong>AND</strong> provides therapeutic Deep Touch Pressure. Think of it this way: a regular mask is passive, Luna Nord is active therapy. You're not just blocking distractions—you're actively triggering your body's natural sleep mechanisms.</p>\n    </details>\n\n    <details>\n      <summary>What's the scientific evidence behind this?</summary>\n      <p>Deep Touch Pressure therapy is backed by <strong>peer-reviewed research published in the National Institutes of Health</strong>, showing significant improvements in sleep quality, reduced anxiety, and optimized hormone production. Studies demonstrate a 42% reduction in cortisol and 32% increase in melatonin with consistent weighted therapy use.</p>\n    </details>\n\n    <details>\n      <summary>How long before I see results?</summary>\n      <p>Most users report improvements within <strong>3-7 nights</strong>. Your nervous system responds immediately to Deep Touch Pressure, but optimal results come after 2-3 weeks as your circadian rhythm stabilizes and hormone production optimizes.</p>\n    </details>\n  </section>\n\n  <!-- TESTIMONIALS -->\n  <section class=\"sci-testimonial-section\">\n    <div class=\"sci-container\">\n      <span style=\"font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: var(--luna-pink); font-weight: 700; display: block; margin-bottom: 12px;\">Real Results</span>\n      <h2 class=\"sci-title\" style=\"color: white; font-size: 36px; margin-bottom: 16px;\">What Women Are Saying</h2>\n      <p style=\"color: rgba(255,255,255,0.7); max-width: 600px; margin: 0 auto;\">\n        2,847 women have transformed their sleep with Luna Nord's science-backed design.\n      </p>\n\n      <div class=\"sci-testimonial-grid\">\n        <div class=\"sci-testimonial-card\">\n          <p class=\"sci-testimonial-text\">\"As a neuroscientist, I was skeptical—but the research is solid. After 2 weeks, my sleep tracker shows 40% more deep sleep. This actually works.\"</p>\n          <div class=\"sci-testimonial-author\">\n            <div class=\"sci-testimonial-avatar\">DR</div>\n            <div>\n              <div class=\"sci-testimonial-name\">Dr. Rachel M.</div>\n              <div class=\"sci-testimonial-title\">Neuroscientist, Boston</div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"sci-testimonial-card\">\n          <p class=\"sci-testimonial-text\">\"I've had insomnia for 15 years. Nothing worked until Luna Nord. The pressure genuinely calms my racing thoughts. I fall asleep in 20 minutes now.\"</p>\n          <div class=\"sci-testimonial-author\">\n            <div class=\"sci-testimonial-avatar\">JK</div>\n            <div>\n              <div class=\"sci-testimonial-name\">Jennifer K.</div>\n              <div class=\"sci-testimonial-title\">Marketing Director, NYC</div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"sci-testimonial-card\">\n          <p class=\"sci-testimonial-text\">\"My anxiety was keeping me up every night. The Deep Touch Pressure is like a hug for your brain. Best $35 I've ever spent on my health.\"</p>\n          <div class=\"sci-testimonial-author\">\n            <div class=\"sci-testimonial-avatar\">SM</div>\n            <div>\n              <div class=\"sci-testimonial-name\">Sarah M.</div>\n              <div class=\"sci-testimonial-title\">Nurse, Chicago</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FINAL CTA -->\n  <section class=\"sci-cta\">\n    <h2 class=\"sci-title\" style=\"color: white; font-size: 38px; margin-bottom: 20px;\">Experience the Science of Better Sleep</h2>\n    <p style=\"color: rgba(255,255,255,0.8); max-width: 650px; margin: 0 auto; font-size: 17px;\">\n      Join thousands of women using clinically-backed Deep Touch Pressure therapy to fall asleep faster, stay asleep longer, and wake up refreshed.\n    </p>\n    <a href=\"https://thelunanord.com/products/weighted-eye-mask-with-hot-cold-therapy\" class=\"sci-btn\">Try Luna Nord Risk-Free →</a>\n    <p class=\"sci-guarantee\">\n      <strong>30-Night Sleep Better Guarantee</strong> · Free Shipping · 2,847 Women Love It\n    </p>\n  </section>\n\n</div>",
