      "settings": {
        "display_id": false,
        "visibility": "desktop-hidden",
        "custom_liquid": "<style>\n  /* ========================================\n     LUNA NORD PRODUCT GRID - 2 COLUMNS + ALL CONVERSION ELEMENTS\n     ======================================== */\n  \n  .lunanord-product-grid-section {\n    background: linear-gradient(180deg, #FFFFFF 0%, #F8F9FA 100%);\n    padding: 80px 20px 100px 20px;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n  }\n\n  .lunanord-grid-container {\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n\n  .lunanord-grid-header {\n    text-align: center;\n    margin-bottom: 50px;\n  }\n\n  .lunanord-grid-title {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: 44px;\n    font-weight: 400;\n    color: #1a1a1a;\n    margin: 0 0 16px 0;\n    letter-spacing: -0.5px;\n    line-height: 1.2;\n  }\n\n  .lunanord-grid-subtitle {\n    font-size: 17px;\n    color: #6B7280;\n    font-weight: 400;\n    line-height: 1.6;\n    max-width: 640px;\n    margin: 0 auto;\n  }\n\n  /* GRID - 2 COLUMNS */\n  .lunanord-product-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 32px;\n    margin-bottom: 40px;\n  }\n\n  /* Third card spans full width on desktop */\n  .lunanord-product-card:nth-child(3) {\n    grid-column: 1 / -1;\n    max-width: 520px;\n    margin: 0 auto;\n    width: 100%;\n  }\n\n  .lunanord-product-card {\n    background: #FFFFFF;\n    border-radius: 12px;\n    overflow: hidden;\n    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);\n    box-shadow: 0 2px 12px rgba(0,0,0,0.06);\n    position: relative;\n    cursor: pointer;\n  }\n\n  .lunanord-product-card:hover {\n    transform: translateY(-6px);\n    box-shadow: 0 12px 32px rgba(0,0,0,0.12);\n  }\n\n  .lunanord-product-card.most-popular {\n    border: 2px solid #F3C5D4;\n    transform: scale(1.02);\n  }\n\n  .lunanord-product-card.most-popular:hover {\n    transform: scale(1.02) translateY(-6px);\n  }\n\n  .lunanord-card-image-wrapper {\n    position: relative;\n    width: 100%;\n    padding-top: 100%;\n    background: #F5F5F5;\n    overflow: hidden;\n  }\n\n  .lunanord-card-image {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .lunanord-product-card:hover .lunanord-card-image {\n    transform: scale(1.05);\n  }\n\n  .lunanord-product-badge {\n    position: absolute;\n    top: 16px;\n    left: 16px;\n    background: rgba(255, 255, 255, 0.95);\n    backdrop-filter: blur(10px);\n    padding: 6px 14px;\n    border-radius: 20px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n    color: #1a1a1a;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n    z-index: 10;\n  }\n\n  .lunanord-savings-badge {\n    position: absolute;\n    top: 16px;\n    right: 16px;\n    background: #F3C5D4;\n    color: #FFFFFF;\n    padding: 6px 12px;\n    border-radius: 20px;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n    box-shadow: 0 2px 8px rgba(243, 197, 212, 0.3);\n    z-index: 10;\n  }\n\n  .lunanord-free-gifts-badge {\n    position: absolute;\n    top: 56px;\n    left: 16px;\n    background: #10B981;\n    color: white;\n    padding: 6px 12px;\n    border-radius: 20px;\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n    z-index: 10;\n  }\n\n  .lunanord-card-content {\n    padding: 24px 20px 28px 20px;\n    text-align: center;\n  }\n\n  .lunanord-package-name {\n    font-family: 'Playfair Display', Georgia, serif;\n    font-size: 26px;\n    font-weight: 400;\n    color: #1a1a1a;\n    margin: 0 0 8px 0;\n    line-height: 1.3;\n  }\n\n  .lunanord-package-description {\n    font-size: 14px;\n    color: #6B7280;\n    font-weight: 400;\n    margin-bottom: 16px;\n    line-height: 1.5;\n  }\n\n  .lunanord-price-wrapper {\n    margin-bottom: 12px;\n  }\n\n  .lunanord-price {\n    font-size: 32px;\n    font-weight: 600;\n    color: #1a1a1a;\n    letter-spacing: -0.5px;\n  }\n\n  .lunanord-original-price {\n    text-decoration: line-through;\n    color: #999;\n    font-size: 18px;\n    font-weight: 400;\n    margin-right: 8px;\n    display: inline-block;\n  }\n\n  .lunanord-savings-text {\n    display: block;\n    font-size: 13px;\n    color: #10B981;\n    font-weight: 600;\n    margin-top: 6px;\n  }\n\n  .lunanord-price-per-unit {\n    display: block;\n    font-size: 13px;\n    color: #999;\n    margin-top: 4px;\n    font-weight: 400;\n  }\n\n  .lunanord-value-prop {\n    font-size: 14px;\n    color: #4B5563;\n    margin-bottom: 18px;\n    line-height: 1.5;\n  }\n\n  .lunanord-value-prop strong {\n    font-weight: 600;\n    color: #1a1a1a;\n  }\n\n  .lunanord-free-gifts-box {\n    background: linear-gradient(135deg, #FFF5F7, #FFE4E9);\n    border: 2px dashed #F3C5D4;\n    padding: 12px;\n    border-radius: 8px;\n    margin: 12px 0 16px 0;\n    text-align: left;\n  }\n\n  .lunanord-free-gifts-title {\n    font-size: 12px;\n    font-weight: 700;\n    color: #F3C5D4;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 6px;\n  }\n\n  .lunanord-free-gifts-list {\n    font-size: 12px;\n    color: #4B5563;\n    line-height: 1.6;\n    margin: 0;\n  }\n\n  .lunanord-includes {\n    list-style: none;\n    padding: 0;\n    margin: 16px 0;\n    text-align: left;\n  }\n\n  .lunanord-includes li {\n    font-size: 13px;\n    color: #6B7280;\n    padding: 6px 0;\n    padding-left: 24px;\n    position: relative;\n    line-height: 1.5;\n  }\n\n  .lunanord-includes li::before {\n    content: '✓';\n    position: absolute;\n    left: 0;\n    color: #F3C5D4;\n    font-weight: 600;\n    font-size: 14px;\n  }\n\n  .lunanord-add-to-cart {\n    display: inline-block;\n    width: 100%;\n    background: #F3C5D4;\n    color: #FFFFFF;\n    font-size: 15px;\n    font-weight: 600;\n    padding: 16px 32px;\n    border: none;\n    border-radius: 6px;\n    cursor: pointer;\n    transition: all 0.3s ease;\n    text-decoration: none;\n    letter-spacing: 0.3px;\n  }\n\n  .lunanord-add-to-cart:hover {\n    background: #E8B4C8;\n    transform: translateY(-2px);\n    box-shadow: 0 6px 20px rgba(243, 197, 212, 0.3);\n  }\n\n  .most-popular .lunanord-add-to-cart {\n    background: #1a1a1a;\n  }\n\n  .most-popular .lunanord-add-to-cart:hover {\n    background: #333;\n    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);\n  }\n\n  /* ========================================\n     TABLET OPTIMIZATION\n     ======================================== */\n  \n  @media (max-width: 968px) {\n    .lunanord-product-grid-section {\n      padding: 60px 20px 80px 20px;\n    }\n\n    .lunanord-product-grid {\n      gap: 24px;\n    }\n    \n    .lunanord-grid-title {\n      font-size: 36px;\n    }\n\n    .lunanord-product-card.most-popular {\n      transform: scale(1);\n    }\n\n    .lunanord-product-card:nth-child(3) {\n      max-width: 100%;\n    }\n  }\n\n  /* ========================================\n     MOBILE OPTIMIZATION\n     ======================================== */\n  \n  @media (max-width: 640px) {\n    .lunanord-product-grid-section {\n      padding: 50px 16px 70px 16px;\n    }\n\n    .lunanord-grid-title {\n      font-size: 28px;\n    }\n\n    .lunanord-grid-subtitle {\n      font-size: 15px;\n    }\n\n    .lunanord-product-grid {\n      grid-template-columns: 1fr;\n      gap: 24px;\n      max-width: 420px;\n      margin: 0 auto;\n    }\n\n    .lunanord-product-card:nth-child(3) {\n      grid-column: 1;\n    }\n\n    .lunanord-card-content {\n      padding: 20px 16px 24px 16px;\n    }\n\n    .lunanord-package-name {\n      font-size: 22px;\n    }\n\n    .lunanord-price {\n      font-size: 28px;\n    }\n  }\n</style>\n\n<!-- ========================================\n     LUNA NORD PRODUCT GRID - 2 COLUMNS\n     ======================================== -->\n<section class=\"lunanord-product-grid-section\">\n  <div class=\"lunanord-grid-container\">\n    \n    <div class=\"lunanord-grid-header\">\n      <h2 class=\"lunanord-grid-title\">Choose Your Sleep Reset</h2>\n      <p class=\"lunanord-grid-subtitle\">\n        One for your nightstand. One for travel. One to gift the friend who needs this.\n      </p>\n    </div>\n\n    <div class=\"lunanord-product-grid\">\n\n      <!-- SINGLE PACK -->\n      <div class=\"lunanord-product-card\">\n        <div class=\"lunanord-card-image-wrapper\">\n          <span class=\"lunanord-product-badge\">Single</span>\n          <span class=\"lunanord-savings-badge\">Save $25</span>\n          <img \n            src=\"https://cdn.shopify.com/s/files/1/0953/1329/7782/files/Gemini_Generated_Image_bz3dadbz3dadbz3d.png?v=1767900352\" \n            alt=\"Luna Nord Single Pack\" \n            class=\"lunanord-card-image\"\n            loading=\"lazy\"\n          >\n        </div>\n        <div class=\"lunanord-card-content\">\n          <h3 class=\"lunanord-package-name\">Single</h3>\n          <p class=\"lunanord-package-description\">+ Free Gifts</p>\n          \n          <div class=\"lunanord-price-wrapper\">\n            <span class=\"lunanord-original-price\">$59.95</span>\n            <span class=\"lunanord-price\">$34.96</span>\n            <span class=\"lunanord-savings-text\">You save $24.99</span>\n          </div>\n\n          <p class=\"lunanord-value-prop\">\n            Perfect for <strong>testing</strong> Luna Nord\n          </p>\n\n          <a \n            href=\"https://thelunanord.com/products/weighted-eye-mask-with-hot-cold-therapy\" \n            class=\"lunanord-add-to-cart\"\n          >\n            Choose Single →\n          </a>\n        </div>\n      </div>\n\n      <!-- FRIENDS PACK (MOST POPULAR) -->\n      <div class=\"lunanord-product-card most-popular\">\n        <div class=\"lunanord-card-image-wrapper\">\n          <span class=\"lunanord-product-badge\">Most Popular</span>\n          <span class=\"lunanord-savings-badge\">Save $57</span>\n          <span class=\"lunanord-free-gifts-badge\">🎁 + Free Gifts</span>\n          <img \n            src=\"https://cdn.shopify.com/s/files/1/0953/1329/7782/files/Gemini_Generated_Image_nwj6jwnwj6jwnwj6.png?v=1767899770\" \n            alt=\"Luna Nord Friends Pack\" \n            class=\"lunanord-card-image\"\n            loading=\"lazy\"\n          >\n        </div>\n        <div class=\"lunanord-card-content\">\n          <h3 class=\"lunanord-package-name\">Friends Pack</h3>\n          <p class=\"lunanord-package-description\">Buy 2 & Save</p>\n          \n          <div class=\"lunanord-price-wrapper\">\n            <span class=\"lunanord-original-price\">$119.90</span>\n            <span class=\"lunanord-price\">$62.93</span>\n            <span class=\"lunanord-price-per-unit\">$31.47 each</span>\n            <span class=\"lunanord-savings-text\">You save $56.97</span>\n          </div>\n\n          <!-- FREE GIFTS BOX -->\n          <div class=\"lunanord-free-gifts-box\">\n            <div class=\"lunanord-free-gifts-title\">🎁 Free Gifts Included:</div>\n            <div class=\"lunanord-free-gifts-list\">\n              📖 Relaxation Guide (PDF)<br>\n              🎧 Deep Sleep Meditation (15min)\n            </div>\n          </div>\n\n          <p class=\"lunanord-value-prop\">\n            One for <strong>home</strong>, one for <strong>travel</strong>\n          </p>\n\n          <a \n            href=\"https://thelunanord.com/products/weighted-eye-mask-with-hot-cold-therapy\" \n            class=\"lunanord-add-to-cart\"\n          >\n            Choose Friends Pack →\n          </a>\n        </div>\n      </div>\n\n      <!-- FAMILY PACK (SPANS FULL WIDTH) -->\n      <div class=\"lunanord-product-card\">\n        <div class=\"lunanord-card-image-wrapper\">\n          <span class=\"lunanord-product-badge\">Best Value</span>\n          <span class=\"lunanord-savings-badge\">Save $96</span>\n          <span class=\"lunanord-free-gifts-badge\">🎁 + Free Gifts</span>\n          <img \n            src=\"https://cdn.shopify.com/s/files/1/0953/1329/7782/files/Gemini_Generated_Image_i9x8hti9x8hti9x8.png?v=1767900040\" \n            alt=\"Luna Nord Family Pack\" \n            class=\"lunanord-card-image\"\n            loading=\"lazy\"\n          >\n        </div>\n        <div class=\"lunanord-card-content\">\n          <h3 class=\"lunanord-package-name\">Family Pack</h3>\n          <p class=\"lunanord-package-description\">Buy 3 & Save</p>\n          \n          <div class=\"lunanord-price-wrapper\">\n            <span class=\"lunanord-original-price\">$179.85</span>\n            <span class=\"lunanord-price\">$83.90</span>\n            <span class=\"lunanord-price-per-unit\">$27.97 each</span>\n            <span class=\"lunanord-savings-text\">You save $95.95</span>\n          </div>\n\n          <!-- FREE GIFTS BOX -->\n          <div class=\"lunanord-free-gifts-box\">\n            <div class=\"lunanord-free-gifts-title\">🎁 Free Gifts Included:</div>\n            <div class=\"lunanord-free-gifts-list\">\n              📖 Relaxation Guide (PDF)<br>\n              🎧 Deep Sleep Meditation (15min)\n            </div>\n          </div>\n\n          <p class=\"lunanord-value-prop\">\n            <strong>Best value</strong> for families or gifting\n          </p>\n\n          <a \n            href=\"https://thelunanord.com/products/weighted-eye-mask-with-hot-cold-therapy\" \n            class=\"lunanord-add-to-cart\"\n          >\n            Choose Family Pack →\n          </a>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n</section>",
