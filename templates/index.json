        "visibility": "mobile-hidden",
        "custom_liquid": "<style>\n  /* TRUST BAR - Calm & Conversion-Focused */\n  .lunanord-trust-bar {\n    background: #FFFFFF;\n    padding: 24px 40px;\n    border-top: 1px solid #E5E7EB;\n    border-bottom: 1px solid #E5E7EB;\n  }\n\n  .lunanord-trust-container {\n    max-width: 1200px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 30px;\n    align-items: center;\n  }\n\n  /* Single Badge */\n  .lunanord-trust-badge {\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n  }\n\n  /* Icon - Your original size */\n  .lunanord-trust-icon {\n    width: 40px;\n    height: 40px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: linear-gradient(135deg, #FFF5F8, #FFF);\n    border-radius: 50%;\n    margin-bottom: 6px;\n    border: 1px solid #FEE;\n  }\n\n  .lunanord-trust-icon svg {\n    width: 20px;\n    height: 20px;\n    stroke: #F3C5D4; /* Your soft pink */\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* Payment Icons */\n  .lunanord-payment-icons {\n    display: flex;\n    gap: 6px;\n    justify-content: center;\n    margin-top: 4px;\n  }\n\n  .lunanord-payment-icon {\n    width: 32px;\n    height: 20px;\n    background: #F9FAFB;\n    border: 1px solid #E5E7EB;\n    border-radius: 3px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 8px;\n    font-weight: 700;\n    color: #6B7280;\n  }\n\n  /* Text - Your original minimal style */\n  .lunanord-trust-title {\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    font-weight: 600; /* 700 → 600 for softer look */\n    color: #1a1d2e;\n    margin: 0;\n    line-height: 1.2;\n  }\n\n  .lunanord-trust-subtitle {\n    font-family: 'Inter', sans-serif;\n    font-size: 12px;\n    color: #6B7280;\n    margin: 0;\n    line-height: 1.3;\n    font-weight: 400;\n  }\n\n  /* Highlight - Your soft pink */\n  .lunanord-trust-highlight {\n    font-weight: 600;\n    color: #F3C5D4;\n  }\n\n  /* Responsive */\n  @media (max-width: 968px) {\n    .lunanord-trust-container {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 24px;\n    }\n\n    .lunanord-trust-bar {\n      padding: 20px 24px;\n    }\n  }\n\n  @media (max-width: 640px) {\n    .lunanord-trust-container {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 20px;\n    }\n\n    .lunanord-trust-bar {\n      padding: 16px 20px;\n    }\n\n    .lunanord-trust-title {\n      font-size: 13px;\n    }\n\n    .lunanord-trust-subtitle {\n      font-size: 11px;\n    }\n  }\n</style>\n\n<!-- TRUST BAR - Conversion Copy + Calm Design -->\n<section class=\"lunanord-trust-bar\">\n  <div class=\"lunanord-trust-container\">\n    \n    <!-- Badge 1: Social Proof (Believable number) -->\n    <div class=\"lunanord-trust-badge\">\n      <div class=\"lunanord-trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\">\n          <path d=\"M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z\"/>\n        </svg>\n      </div>\n      <h3 class=\"lunanord-trust-title\">2,847 Women Love It</h3>\n      <p class=\"lunanord-trust-subtitle\">Join the community</p>\n    </div>\n\n    <!-- Badge 2: Free Shipping (Addresses \"is it worth it?\" objection) -->\n    <div class=\"lunanord-trust-badge\">\n      <div class=\"lunanord-trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\">\n          <path d=\"M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z\"/>\n        </svg>\n      </div>\n      <h3 class=\"lunanord-trust-title\">Free Shipping</h3>\n      <p class=\"lunanord-trust-subtitle\">All US orders</p>\n    </div>\n\n    <!-- Badge 3: 30-Night Guarantee (Customer language: \"nights\" not \"days\") -->\n    <div class=\"lunanord-trust-badge\">\n      <div class=\"lunanord-trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\">\n          <path d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"/>\n        </svg>\n      </div>\n      <h3 class=\"lunanord-trust-title\">30-Night Guarantee</h3>\n      <p class=\"lunanord-trust-subtitle\">Sleep better or refund</p>\n    </div>\n\n    <!-- Badge 4: Secure Payment -->\n    <div class=\"lunanord-trust-badge\">\n      <div class=\"lunanord-trust-icon\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\">\n          <path d=\"M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3v-8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z\"/>\n        </svg>\n      </div>\n      <h3 class=\"lunanord-trust-title\">Secure Payment</h3>\n      <div class=\"lunanord-payment-icons\">\n        <div class=\"lunanord-payment-icon\">VISA</div>\n        <div class=\"lunanord-payment-icon\">MC</div>\n        <div class=\"lunanord-payment-icon\">PP</div>\n      </div>\n    </div>\n\n  </div>\n</section>",
