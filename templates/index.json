        "display_id": false,
        "visibility": "mobile-hidden",
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap');\n\n  /* --- BENEFITS SECTION - MATCHING YOUR STYLE --- */\n  .lunanord-benefits-section {\n    background: #F5F5F5;\n    padding: 70px 40px;\n    font-family: 'Inter', sans-serif;\n  }\n\n  .lunanord-benefits-container {\n    max-width: 1400px;\n    margin: 0 auto;\n    text-align: center;\n  }\n\n  /* --- HEADERS (Matching your hero style) --- */\n  .lunanord-benefits-tag {\n    display: inline-block;\n    margin-bottom: 20px;\n    font-size: 13px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #6B7280;\n    font-weight: 600;\n  }\n\n  .lunanord-benefits-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 46px;\n    line-height: 1.25;\n    margin-bottom: 16px;\n    font-weight: 500;\n    color: #1a1d2e;\n    letter-spacing: -0.5px;\n  }\n\n  .lunanord-benefits-subtitle {\n    font-family: 'Inter', sans-serif;\n    font-size: 17px;\n    color: #6B7280;\n    max-width: 680px;\n    margin: 0 auto 60px;\n    line-height: 1.65;\n    font-weight: 400;\n  }\n\n  .lunanord-benefits-subtitle strong {\n    font-weight: 600;\n    color: #4B5563;\n  }\n\n  /* --- BENEFITS GRID --- */\n  .lunanord-benefits-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 30px;\n    margin-bottom: 80px;\n  }\n\n  .lunanord-benefit-card {\n    background: #FFFFFF;\n    border: 1px solid #E5E7EB;\n    border-radius: 12px;\n    padding: 40px 28px;\n    text-align: center;\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n\n  .lunanord-benefit-card:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 10px 30px rgba(0,0,0,0.06);\n  }\n\n  .lunanord-benefit-icon {\n    font-size: 36px;\n    margin-bottom: 20px;\n    display: inline-block;\n  }\n\n  .lunanord-benefit-title {\n    font-family: 'Playfair Display', serif;\n    font-size: 20px;\n    font-weight: 500;\n    margin-bottom: 12px;\n    color: #1a1d2e;\n  }\n\n  .lunanord-benefit-desc {\n    font-family: 'Inter', sans-serif;\n    font-size: 15px;\n    line-height: 1.6;\n    color: #4B5563;\n    margin: 0;\n  }\n\n  .lunanord-benefit-desc strong {\n    font-weight: 600;\n    color: #1a1d2e;\n  }\n\n  /* --- TESTIMONIAL CARD --- */\n  .lunanord-testimonial-card {\n    display: grid;\n    grid-template-columns: 1fr 1.2fr;\n    background: #FFFFFF;\n    border-radius: 12px;\n    overflow: hidden;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.06);\n    margin-bottom: 50px;\n    border: 1px solid #E5E7EB;\n  }\n\n  .lunanord-testimonial-image {\n    width: 100%;\n    height: 100%;\n    min-height: 350px;\n    object-fit: cover;\n    display: block;\n  }\n\n  .lunanord-testimonial-content {\n    padding: 50px 40px;\n    text-align: left;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .lunanord-testimonial-stars {\n    color: #F3C5D4;\n    font-size: 18px;\n    letter-spacing: 1px;\n    margin-bottom: 24px;\n  }\n\n  .lunanord-testimonial-quote {\n    font-family: 'Playfair Display', serif;\n    font-size: 24px;\n    line-height: 1.5;\n    color: #1a1d2e;\n    margin-bottom: 28px;\n    font-style: italic;\n  }\n\n  .lunanord-testimonial-quote strong {\n    font-weight: 600;\n    font-style: normal;\n    color: #1a1d2e;\n  }\n\n  .lunanord-testimonial-author {\n    font-family: 'Inter', sans-serif;\n    font-size: 14px;\n    font-weight: 600;\n    color: #1a1d2e;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .lunanord-verified-badge {\n    font-size: 10px;\n    background: #ecfdf5;\n    color: #059669;\n    padding: 3px 8px;\n    border-radius: 4px;\n    font-weight: 700;\n  }\n\n  /* --- CTA BUTTON (Matching your hero) --- */\n  .lunanord-benefits-cta {\n    display: inline-block;\n    background: #F3C5D4;\n    color: #