shrink: 0; /* Prevents dot from squishing */\n    margin-top: 6px; /* Align with first line of text */\n  }\n\n  .dot-red { background: #EF4444; }\n  .dot-green { background: #10B981; }\n\n  /* MOBILE OPTIMIZATION (@media) */\n  @media (max-width: 968px) {\n    .lunanord-editorial {\n      padding: 48px 20px; /* Reduced vertical padding */\n    }\n\n    .lunanord-editorial-container {\n      grid-template-columns: 1fr;\n      gap: 40px; /* Reduced gap between text and images */\n    }\n    \n    .lunanord-content-wrapper {\n      padding-top: 0;\n    }\n\n    /* IMPORTANT: Removed 'order: -1'. \n       We want the Headline to show FIRST, then the problem description, \n       then the images. This reduces bounce rate.\n    */\n    .lunanord-image-grid {\n      gap: 16px; /* Tighter image spacing */\n      margin-top: 10px;\n    }\n    \n    .lunanord-quote {\n       margin: 24px 0;\n       padding: 16px;\n    }\n    \n    /* Make stat box pop more on mobile */\n    .lunanord-stat {\n      margin: 24px 0 0 0;\n      background: #ffffff;\n      border: 1px solid #F3C5D4; /* Pink border makes it stand out */\n    }\n  }\n</style>\n\n<section class=\"lunanord-editorial\">\n  <div class=\"lunanord-editorial-container\">\n    \n    <div class=\"lunanord-content-wrapper\">\n      <span class=\"lunanord-eyebrow\">The Problem</span>\n      \n      <h2 class=\"lunanord-headline\">You're not failing. Your sleep environment is.</h2>\n\n      <p class=\"lunanord-body-text\">\n        If you lie awake for <strong>1-2 hours replaying tomorrow's to-do list</strong>, you're not broken. Your sleep is failing because of <strong>two things working against you simultaneously</strong>—and most solutions only address one.\n      </p>\n\n      <ul class=\"lunanord-problems-list\">\n        <li data-number=\"1.\">\n          <strong>Ambient light hijacks melatonin.</strong> Streetlamps, phones, or early sun disrupt your brain's sleep hormones.\n        </li>\n        <li data-number=\"2.\">