            "custom_liquid": "<style>\n  /* Tyylit bannerille - Kompakti ja Clean */\n  .clean-gift-banner {\n    display: flex;\n    align-items: center;\n    background-color: #ffffff;\n    border: 1px solid #e5e5e5; /* Hyvin vaalea, huomaamaton reunus */\n    border-radius: 6px; /* Hieman pienempi pyöristys */\n    padding: 8px 12px; /* VÄHENNETTY: Pienemmät välit reunoilla */\n    margin-bottom: 15px;\n    font-family: inherit;\n    max-width: 100%;\n    line-height: 1.2; /* Tiivistää tekstirivejä */\n  }\n\n  /* Ikonin säilö */\n  .gift-icon-container {\n    flex-shrink: 0;\n    margin-right: 12px; /* Pienempi väli kuvan ja tekstin välissä */\n  }\n\n  /* Ikonin kuva */\n  .gift-icon-container img {\n    width: 42px; /* VÄHENNETTY: Pienempi ikoni (oli 60px) */\n    height: auto;\n    display: block;\n    object-fit: contain;\n  }\n\n  /* Tekstiosio */\n  .gift-text-container {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  /* Otsikko */\n  .gift-headline {\n    font-size: 14px; /* Hieman pienempi fontti */\n    font-weight: 700;\n    color: #000000;\n    margin: 0 0 2px 0; /* Hyvin pieni väli otsikon alla */\n    letter-spacing: -0.01em;\n  }\n\n  /* Alaotsikko */\n  .gift-subline {\n    font-size: 13px; /* Pienempi, siisti fontti */\n    font-weight: 400;\n    color: #555555; /* Tummanharmaa, ei ihan musta */\n    margin: 0;\n  }\n\n  /* Mobiilisäätö */\n  @media (max-width: 480px) {\n    .clean-gift-banner {\n        padding: 8px 10px;\n    }\n    .gift-headline {\n      font-size: 13px;\n    }\n    .gift-subline {\n      font-size: 12px;\n    }\n  }\n</style>\n\n<div class=\"clean-gift-banner\">\n  \n  <div class=\"gift-icon-container\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0953/1329/7782/files/Nimeton_malli_40.png?v=1765892568\" alt=\"Free Gifts\">\n  </div>\n\n  <div class=\"gift-text-container\">\n    <div class=\"gift-headline\">+ Limited time only: 2 Free gifts</div>\n    <div class=\"gift-subline\">Relaxation Guide & Deep Sleep Meditation</div>\n  </div>\n\n</div>"
