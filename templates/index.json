        "custom_liquid_3Cp6TE": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n\n  /* --- TYYLIT --- */\n\n  .sleek-slider-wrapper {\n\n    width: 100%;\n\n    margin-top: 15px;\n\n    margin-bottom: 15px; /* Vähemmän väliä alaspäin */\n\n    padding: 15px 0;\n\n    border-top: 1px solid #F0F0F0; /* Todella haalea viiva erottimeksi */\n\n    border-bottom: 1px solid #F0F0F0;\n\n    position: relative;\n\n    font-family: 'Montserrat', sans-serif;\n\n  }\n\n\n\n  .sleek-slider-content {\n\n    display: flex;\n\n    align-items: center;\n\n    justify-content: space-between; /* Nuolet laidoille, teksti keskelle */\n\n    gap: 10px;\n\n  }\n\n\n\n  /* Nuolet (Minimalistiset) */\n\n  .sleek-arrow {\n\n    background: none;\n\n    border: none;\n\n    cursor: pointer;\n\n    font-size: 18px; /* Pieni ja siro */\n\n    color: #999; /* Haalea harmaa */\n\n    padding: 0 5px;\n\n    transition: color 0.2s;\n\n    user-select: none;\n\n  }\n\n\n\n  .sleek-arrow:hover {\n\n    color: #1C1C1C; /* Tummuu hieman hoverissa */\n\n  }\n\n\n\n  /* Tekstialue */\n\n  .sleek-slide-container {\n\n    flex: 1;\n\n    text-align: center;\n\n    overflow: hidden;\n\n  }\n\n\n\n  .sleek-slide {\n\n    display: none; /* Piilotetaan kaikki oletuksena */\n\n    animation: fadeIn 0.4s ease;\n\n  }\n\n\n\n  .sleek-slide.active {\n\n    display: block; /* Näytetään vain aktiivinen */\n\n  }\n\n\n\n  /* Lainaus */\n\n  .sleek-quote {\n\n    font-size: 12px; /* Pieni, hienostunut koko */\n\n    line-height: 1.4;\n\n    color: #333;\n\n    font-style: italic;\n\n    margin: 0 0 4px 0; /* Hyvin pieni väli nimeen */\n\n    padding: 0 10px;\n\n  }\n\n\n\n  /* Nimi ja Tähdet samalle riville säästääksemme tilaa */\n\n  .sleek-meta {\n\n    display: flex;\n\n    align-items: center;\n\n    justify-content: center;\n\n    gap: 8px;\n\n    font-size: 10px; /* Hyvin pieni \"Editorial\" koko */\n\n    text-transform: uppercase;\n\n    letter-spacing: 1px;\n\n    color: #666;\n\n  }\n\n\n\n  .sleek-stars {\n\n    color: #1C1C1C; /* Mustat tähdet ovat enemmän \"fashion/luxury\" kuin keltaiset */\n\n    font-size: 10px;\n\n    letter-spacing: 1px;\n\n  }\n\n\n\n  @keyframes fadeIn {\n\n    from { opacity: 0; transform: translateY(2px); }\n\n    to { opacity: 1; transform: translateY(0); }\n\n  }\n\n</style>\n\n\n\n<div class=\"sleek-slider-wrapper\">\n\n  <div class=\"sleek-slider-content\">\n\n    \n\n    <button class=\"sleek-arrow\" onclick=\"changeSleekSlide(-1)\">‹</button>\n\n\n\n    <div class=\"sleek-slide-container\">\n\n      \n\n      <div class=\"sleek-slide active\">\n\n        <p class=\"sleek-quote\">\"The gentle pressure knocked me out instantly on my flight!\"</p>\n\n        <div class=\"sleek-meta\">\n\n          <span class=\"sleek-stars\">★★★★★</span>\n\n          <span>Olivia S.</span>\n\n        </div>\n\n      </div>\n\n\n\n      <div class=\"sleek-slide\">\n\n        <p class=\"sleek-quote\">\"Finally a mask that actually blocks 100% of light.\"</p>\n\n        <div class=\"sleek-meta\">\n\n          <span class=\"sleek-stars\">★★★★★</span>\n\n          <span>Emily R.</span>\n\n        </div>\n\n      </div>\n\n\n\n      <div class=\"sleek-slide\">\n\n        <p class=\"sleek-quote\">\"Cooling side is a lifesaver for my migraines.\"</p>\n\n        <div class=\"sleek-meta\">\n\n          <span class=\"sleek-stars\">★★★★★</span>\n\n          <span>Sarah J.</span>\n\n        </div>\n\n      </div>\n\n\n\n    </div>\n\n\n\n    <button class=\"sleek-arrow\" onclick=\"changeSleekSlide(1)\">›</button>\n\n\n\n  </div>\n\n</div>\n\n\n\n<script>\n\n  let sleekIndex = 0;\n\n  const sleekSlides = document.querySelectorAll('.sleek-slide');\n\n\n\n  function showSleekSlide(n) {\n\n    // Piilota kaikki\n\n    sleekSlides.forEach(slide => slide.classList.remove('active'));\n\n    \n\n    // Laske indeksi\n\n    sleekIndex += n;\n\n    if (sleekIndex >= sleekSlides.length) sleekIndex = 0;\n\n    if (sleekIndex < 0) sleekIndex = sleekSlides.length - 1;\n\n\n\n    // Näytä uusi\n\n    sleekSlides[sleekIndex].classList.add('active');\n\n  }\n\n\n\n  function changeSleekSlide(n) {\n\n    showSleekSlide(n);\n\n  }\n\n</script>"
