      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Luna Nord - Trust Bar Balanced</title>\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  :root {\n    --midnight: #1A1A2E;\n    --moon-white: #F8F6F3;\n    --charcoal: #3F3F3F;\n    --dusty-rose: #C9ADA7;\n    --mist: #E6E8EA;\n  }\n\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  body {\n    font-family: 'DM Sans', sans-serif;\n    background: var(--moon-white);\n  }\n\n  /* BALANCED TRUST BAR */\n  .trust-bar {\n    background: white;\n    border-top: 1px solid var(--mist);\n    border-bottom: 1px solid var(--mist);\n    padding: 28px 40px;\n    position: relative;\n  }\n\n  .trust-bar__container {\n    max-width: 1200px;\n    margin: 0 auto;\n    display: flex;\n    align-items: center;\n    justify-content: space-around;\n    gap: 48px;\n  }\n\n  .trust-bar__item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    flex: 1;\n    text-align: center;\n  }\n\n  /* NUMBER - Smaller, more balanced */\n  .trust-bar__number {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 44px;\n    font-weight: 700;\n    color: var(--midnight);\n    line-height: 1;\n    letter-spacing: -0.5px;\n  }\n\n  /* LABEL */\n  .trust-bar__label {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 1.8px;\n    text-transform: uppercase;\n    color: var(--charcoal);\n    margin-top: 4px;\n  }\n\n  /* SUBTLE ACCENT LINE */\n  .trust-bar__accent {\n    width: 32px;\n    height: 2px;\n    background: var(--dusty-rose);\n    margin-top: 6px;\n  }\n\n  /* RESPONSIVE */\n  @media (max-width: 968px) {\n    .trust-bar {\n      padding: 24px 24px;\n    }\n\n    .trust-bar__container {\n      gap: 36px;\n    }\n\n    .trust-bar__number {\n      font-size: 40px;\n    }\n\n    .trust-bar__label {\n      font-size: 10px;\n      letter-spacing: 1.5px;\n    }\n  }\n\n  @media (max-width: 640px) {\n    .trust-bar {\n      padding: 20px;\n    }\n\n    .trust-bar__container {\n      flex-direction: column;\n      gap: 28px;\n    }\n\n    .trust-bar__number {\n      font-size: 42px;\n    }\n\n    .trust-bar__label {\n      font-size: 10px;\n    }\n  }\n</style>\n</head>\n<body>\n\n<section class=\"trust-bar\">\n  <div class=\"trust-bar__container\">\n    \n    <div class=\"trust-bar__item\">\n      <div class=\"trust-bar__number\">100%</div>\n      <div class=\"trust-bar__label\">Science-Backed</div>\n      <div class=\"trust-bar__accent\"></div>\n    </div>\n\n    <div class=\"trust-bar__item\">\n      <div class=\"trust-bar__number\">14min</div>\n      <div class=\"trust-bar__label\">Faster Asleep</div>\n      <div class=\"trust-bar__accent\"></div>\n    </div>\n\n    <div class=\"trust-bar__item\">\n      <div class=\"trust-bar__number\">30</div>\n      <div class=\"trust-bar__label\">Night Guarantee</div>\n      <div class=\"trust-bar__accent\"></div>\n    </div>\n\n  </div>\n</section>\n\n</body>\n</html>",
