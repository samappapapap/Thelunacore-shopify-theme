        "custom_liquid": "<style>\n  /* --- PERUSASETUKSET --- */\n  .nodpod-footer-wrapper {\n    display: grid;\n    grid-template-columns: 35% 1fr; /* Vasen 35%, Oikea loput */\n    width: 100%;\n    background-color: #FAFAFA;\n    border-top: 1px solid #000;\n    color: #4a4a4a;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n  }\n\n  /* --- VASEN PUOLI (Uutiskirje) --- */\n  .nodpod-left {\n    padding: 60px 50px;\n    border-right: 1px solid #000;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* Otsikko */\n  .nodpod-title {\n    font-family: 'Times New Roman', Times, serif; /* Serif-fontti */\n    font-style: italic; /* Kursivointi */\n    font-size: 32px;    /* Iso otsikko */\n    font-weight: 400;\n    margin: 0 0 15px 0;\n    line-height: 1.1;\n    color: #4a4a4a;\n  }\n\n  /* Leipäteksti */\n  .nodpod-text {\n    font-size: 15px;\n    line-height: 1.6;\n    color: #777;\n    margin-bottom: 30px;\n    max-width: 90%;\n  }\n\n  /* --- OIKEA PUOLI (Linkit ja tiedot) --- */\n  .nodpod-right {\n    padding: 60px 50px;\n    display: flex;\n    justify-content: flex-start; /* Tasataan alkuun */\n    gap: 80px; /* Väli sarakkeiden välillä */\n  }\n\n  /* Sarakkeiden otsikot */\n  .nodpod-menu-title {\n    font-size: 18px;\n    margin-bottom: 20px;\n    color: #4a4a4a;\n    font-family: 'Times New Roman', Times, serif;\n    font-weight: 600;\n  }\n\n  /* Linkkilistat ja tekstit */\n  .nodpod-link-list {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n  }\n\n  .nodpod-link-list li {\n    margin-bottom: 12px;\n    font-size: 14px;\n    color: #777;\n  }\n\n  .nodpod-link-list a {\n    text-decoration: none;\n    color: #777;\n    transition: color 0.2s;\n  }\n\n  .nodpod-link-list a:hover {\n    color: #000;\n  }\n\n  /* Kentät ja napit */\n  .nodpod-input {\n    width: 100%;\n    padding: 15px;\n    border: 1px solid #000; /* Musta reunus kuten mallissa */\n    margin-bottom: 15px;\n    background: transparent;\n    font-size: 14px;\n  }\n\n  .nodpod-btn {\n    width: 100%;\n    background-color: #555;\n    color: #fff;\n    padding: 15px;\n    text-transform: uppercase;\n    font-weight: 600;\n    border: none;\n    cursor: pointer;\n    letter-spacing: 1px;\n    font-size: 13px;\n  }\n  \n  .nodpod-btn:hover {\n    background-color: #000;\n  }\n\n  /* --- MOBIILI (alle 768px) --- */\n  @media (max-width: 768px) {\n    .nodpod-footer-wrapper {\n      grid-template-columns: 1fr;\n    }\n    .nodpod-left {\n      border-right: none;\n      border-bottom: 1px solid #000;\n      padding: 40px 20px;\n    }\n    .nodpod-right {\n      padding: 40px 20px;\n      flex-direction: column; /* Linkit allekkain mobiilissa */\n      gap: 40px;\n    }\n  }\n</style>\n\n<div class=\"nodpod-footer-wrapper\">\n  \n  <div class=\"nodpod-left\">\n    <h2 class=\"nodpod-title\">Get a free Digital bonus and mystery discount</h2>\n    <p class=\"nodpod-text\">\n      Subscribe to our newsletter and you'll get a free gift and a mystery discount for your first order.\n    </p>\n    <form style=\"width: 100%;\">\n      <input type=\"email\" placeholder=\"Sähköposti\" class=\"nodpod-input\">\n      <button type=\"button\" class=\"nodpod-btn\">Sign up</button>\n    </form>\n  </div>\n\n  <div class=\"nodpod-right\">\n    \n    <div>\n      <h4 class=\"nodpod-menu-title\">Quick links</h4>\n      <ul class=\"nodpod-link-list\">\n        <li><a href=\"#\">Haku</a></li>\n        <li><a href=\"#\">Shop now</a></li>\n        <li><a href=\"#\">About us</a></li>\n      </ul>\n    </div>\n\n    <div>\n      <h4 class=\"nodpod-menu-title\">Our detail</h4>\n      <ul class=\"nodpod-link-list\">\n        <li>Calminest.</li>\n        <li><a href=\"mailto:Contact@calminest.com\">Contact@calminest.com</a></li>\n        <li><a href=\"mailto:Influencers@calminest.com\">Influencers@calminest.com</a></li>\n        <li><a href=\"mailto:collaborations@calminest.com\">collaborations@calminest.com</a></li>\n      </ul>\n    </div>\n\n  </div>\n\n</div>",
