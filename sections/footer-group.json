{"name":"t:sections.footer.name","type":"footer","sections":{"custom_liquid_tPM4Pr":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"display_id":false,"visibility":"always-display","custom_liquid":"<style>\n  .ln-footer-custom {\n    background: #ffffff;\n    padding: 60px 40px 20px;\n    color: #2f2a28;\n    font-family: Georgia, \"Times New Roman\", serif;\n  }\n\n  .ln-footer-custom * {\n    box-sizing: border-box;\n  }\n\n  .ln-footer-custom__inner {\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  .ln-footer-custom__grid {\n    display: grid;\n    grid-template-columns: 1fr 1.15fr 1fr;\n    gap: 56px;\n    align-items: start;\n  }\n\n  .ln-footer-custom h2,\n  .ln-footer-custom h3 {\n    margin: 0 0 22px;\n    font-size: 40px;\n    line-height: 1.05;\n    font-weight: 600;\n    letter-spacing: -0.02em;\n    color: #2f2a28;\n  }\n\n  .ln-footer-custom__links,\n  .ln-footer-custom__details {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n  }\n\n  .ln-footer-custom__links a,\n  .ln-footer-custom__details a,\n  .ln-footer-custom__details p {\n    margin: 0;\n    font-size: 17px;\n    line-height: 1.8;\n    color: #5a5250;\n    text-decoration: none;\n    transition: color 0.2s ease, opacity 0.2s ease;\n  }\n\n  .ln-footer-custom__links a:hover,\n  .ln-footer-custom__details a:hover {\n    color: #c9959c;\n    opacity: 1;\n  }\n\n  .ln-footer-custom__text {\n    max-width: 430px;\n    margin: 0 0 28px;\n    font-size: 17px;\n    line-height: 1.85;\n    color: #6a615f;\n  }\n\n  .ln-footer-custom__newsletter-form {\n    max-width: 420px;\n  }\n\n  .ln-footer-custom__field {\n    position: relative;\n    margin-bottom: 14px;\n  }\n\n  .ln-footer-custom__field input[type=\"email\"] {\n    width: 100%;\n    height: 58px;\n    border: 1px solid #eadbdd;\n    border-radius: 8px;\n    background: #fffafb;\n    padding: 0 54px 0 18px;\n    font-size: 17px;\n    color: #2f2a28;\n    outline: none;\n    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;\n  }\n\n  .ln-footer-custom__field input[type=\"email\"]::placeholder {\n    color: #918483;\n    opacity: 1;\n  }\n\n  .ln-footer-custom__field input[type=\"email\"]:focus {\n    border-color: #c9959c;\n    background: #ffffff;\n    box-shadow: 0 0 0 3px rgba(201, 149, 156, 0.12);\n  }\n\n  .ln-footer-custom__mail-icon {\n    position: absolute;\n    right: 16px;\n    top: 50%;\n    transform: translateY(-50%);\n    color: #c9959c;\n    font-size: 16px;\n    pointer-events: none;\n  }\n\n  .ln-footer-custom__newsletter-form button {\n    width: 100%;\n    height: 58px;\n    border: 1.5px solid #c9959c;\n    border-radius: 8px;\n    background: #c9959c;\n    color: #ffffff;\n    font-size: 17px;\n    font-weight: 600;\n    cursor: pointer;\n    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;\n  }\n\n  .ln-footer-custom__newsletter-form button:hover {\n    background: #ba888f;\n    border-color: #ba888f;\n    transform: translateY(-1px);\n  }\n\n  .ln-footer-custom__message {\n    margin-top: 12px;\n    font-size: 14px;\n    line-height: 1.6;\n    color: #6a615f;\n  }\n\n  .ln-footer-custom__bottom {\n    border-top: 1px solid #f1e7e9;\n    margin-top: 56px;\n    padding-top: 24px;\n  }\n\n  .ln-footer-custom__payments {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 8px;\n    margin-bottom: 16px;\n  }\n\n  .ln-footer-custom__payments .icon {\n    width: 38px;\n    height: 24px;\n  }\n\n  .ln-footer-custom__legal {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 10px 18px;\n    text-align: center;\n  }\n\n  .ln-footer-custom__copyright {\n    margin: 0;\n    font-size: 14px;\n    line-height: 1.6;\n    color: #8d8180;\n  }\n\n  .ln-footer-custom__legal-links {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 10px 18px;\n  }\n\n  .ln-footer-custom__legal-links a {\n    font-size: 14px;\n    line-height: 1.6;\n    color: #8d8180;\n    text-decoration: none;\n    transition: color 0.2s ease;\n  }\n\n  .ln-footer-custom__legal-links a:hover {\n    color: #c9959c;\n  }\n\n  @media screen and (max-width: 990px) {\n    .ln-footer-custom {\n      padding: 42px 22px 18px;\n    }\n\n    .ln-footer-custom__grid {\n      grid-template-columns: 1fr;\n      gap: 34px;\n    }\n\n    .ln-footer-custom h2,\n    .ln-footer-custom h3 {\n      font-size: 30px;\n      margin-bottom: 18px;\n    }\n\n    .ln-footer-custom__newsletter-form,\n    .ln-footer-custom__text {\n      max-width: 100%;\n    }\n\n    .ln-footer-custom__bottom {\n      margin-top: 38px;\n      padding-top: 20px;\n    }\n\n    .ln-footer-custom__legal {\n      flex-direction: column;\n      gap: 8px;\n    }\n  }\n<\/style>\n\n<div class=\"ln-footer-custom\">\n  <div class=\"ln-footer-custom__inner\">\n    <div class=\"ln-footer-custom__grid\">\n\n      <div>\n        <h3>Quick links<\/h3>\n        <div class=\"ln-footer-custom__links\">\n          <a href=\"https:\/\/thelunanord.com\/search\">Haku<\/a>\n          <a href=\"https:\/\/thelunanord.com\/products\/gentle-pressure-gravity-sleep-eye-mask\">Shop now<\/a>\n          <a href=\"https:\/\/thelunanord.com\/pages\/track-order\">About us<\/a>\n        <\/div>\n      <\/div>\n\n      <div>\n        <h2>Get a free Digital bonus and mystery discount<\/h2>\n        <p class=\"ln-footer-custom__text\">\n          Subscribe to our newsletter and you'll get a free gift and a mystery discount for your first order.\n        <\/p>\n\n        {% form 'customer', class: 'ln-footer-custom__newsletter-form' %}\n          <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n\n          <div class=\"ln-footer-custom__field\">\n            <input\n              type=\"email\"\n              name=\"contact[email]\"\n              placeholder=\"Email\"\n              autocorrect=\"off\"\n              autocapitalize=\"off\"\n              required\n            >\n            <span class=\"ln-footer-custom__mail-icon\">✉<\/span>\n          <\/div>\n\n          <button type=\"submit\">Sign up<\/button>\n\n          {% if form.posted_successfully? %}\n            <p class=\"ln-footer-custom__message\">Thanks for signing up!<\/p>\n          {% endif %}\n\n          {% if form.errors %}\n            <p class=\"ln-footer-custom__message\">{{ form.errors | default_errors }}<\/p>\n          {% endif %}\n        {% endform %}\n      <\/div>\n\n      <div>\n        <h3>Our detail<\/h3>\n        <div class=\"ln-footer-custom__details\">\n          <p>Thelunanord<\/p>\n          <a href=\"mailto:info@thelunanord.com\">info@thelunanord.com<\/a>\n          <a href=\"mailto:Influencers@thelunanord.com\">Influencers@thelunanord.com<\/a>\n          <a href=\"mailto:collaborationsthe@lunanord.com\">collaborationsthe@lunanord.com<\/a>\n        <\/div>\n      <\/div>\n\n    <\/div>\n\n    <div class=\"ln-footer-custom__bottom\">\n      {% if shop.enabled_payment_types != empty %}\n        <div class=\"ln-footer-custom__payments\">\n          {% for type in shop.enabled_payment_types %}\n            {{ type | payment_type_svg_tag: class: 'icon' }}\n          {% endfor %}\n        <\/div>\n      {% endif %}\n\n      <div class=\"ln-footer-custom__legal\">\n        <p class=\"ln-footer-custom__copyright\">\n          © {{ 'now' | date: '%Y' }}, {{ shop.name }}.\n        <\/p>\n\n        <div class=\"ln-footer-custom__legal-links\">\n          <a href=\"https:\/\/thelunanord.com\/policies\/privacy-policy\">Privacy policy<\/a>\n          <a href=\"https:\/\/thelunanord.com\/policies\/#shopifyReshowConsentBanner\">Cookie preferences<\/a>\n        <\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>","color_scheme":"background-1","padding_top":40,"padding_bottom":52}},"footer":{"type":"footer","blocks":{"1c647602-cc00-4009-a058-976435c8ee9e":{"type":"link_list","sett