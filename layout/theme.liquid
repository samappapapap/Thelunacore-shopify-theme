  </style>
  <script>
  (function(){
    function injectLnBtns(){
      var old=document.getElementById('ln-btns');
      if(old)old.remove();
      var c=document.createElement('div');
      c.id='ln-btns';
      c.innerHTML='<div class="ln-btn-row"><button onclick="lnClickThumb(2)" class="ln-btn"><span style="background:#1a1a1a;color:white;border-radius:50%;width:14px;height:14px;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0">▶</span>See It In Action</button><div class="ln-divider"></div><button onclick="lnClickThumb(4)" class="ln-btn"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.5" style="flex-shrink:0"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>See Before &amp; After</button></div>';
      window.lnClickThumb=function(idx){
        var sy=window.scrollY;
        var orig=Element.prototype.scrollIntoView;
        Element.prototype.scrollIntoView=function(){};
        var btns=document.querySelectorAll('.thumbnail-list__item button');
        if(btns[idx])btns[idx].click();
        Element.prototype.scrollIntoView=orig;
        requestAnimationFrame(function(){window.scrollTo(0,sy);});
        setTimeout(function(){window.scrollTo(0,sy);},50);
        setTimeout(function(){window.scrollTo(0,sy);},150);
      };
      var container=document.querySelector('.product__media-container')||document.querySelector('.product__media-wrapper');
      if(container){container.appendChild(c)}
      else{var ml=document.querySelector('.product__media-list');if(ml)ml.insertAdjacentElement('afterend',c)}
    }
    if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',injectLnBtns)}else{injectLnBtns()}
    document.addEventListener('shopify:section:load',injectLnBtns);
    document.addEventListener('shopify:section:reorder',injectLnBtns);
    document.addEventListener('shopify:block:select',injectLnBtns);
  })();
  </script>

